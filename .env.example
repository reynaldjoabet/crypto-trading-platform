# ── Postgres ──────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=trading
PG_PASSWORD=trading
PG_DB=trading
PG_POOL_SIZE=16

# ── HTTP ──────────────────────────────────────────────────────────────────────
PUBLIC_HTTP_HOST=0.0.0.0
PUBLIC_HTTP_PORT=8080
ADMIN_HTTP_HOST=0.0.0.0
ADMIN_HTTP_PORT=8081

# ── OIDC (Keycloak) ───────────────────────────────────────────────────────────
OIDC_ISSUER=http://localhost:8082/realms/trading
OIDC_AUDIENCE=trading-app
OIDC_JWKS_URI=http://localhost:8082/realms/trading/protocol/openid-connect/certs

# ── Exchanges (keep EXCHANGES_LIVE=false to use the in-memory mock) ───────────
EXCHANGES_LIVE=false
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Custody (Fireblocks) ──────────────────────────────────────────────────────
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_PEM_PATH=/run/secrets/fireblocks.pem
FIREBLOCKS_VAULT_ID=0
